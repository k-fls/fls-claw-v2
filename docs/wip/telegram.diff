+/** A channel rejected the message for markup/entity parsing reasons (not transport). */
+export function isFormatError(err: unknown): boolean {
+  const m = err instanceof Error ? err.message : String(err);
+  return /parse entit|find end of the entity|can't parse|Bad Request:.*entit/i.test(m);
+}
+
+/** Strip legacy-Markdown delimiters so text is readable when sent as plain. */
+export function toPlainText(s: string): string {
+  return s
+    .replace(/```([\s\S]*?)```/g, '$1')
+    .replace(/`([^`\n]*)`/g, '$1')
+    .replace(/\*\*?([^*\n]+?)\*\*?/g, '$1')
+    .replace(/__?([^_\n]+?)__?/g, '$1')
+    .replace(/\[([^\]]*)\]\([^)]*\)/g, '$1');
+}
